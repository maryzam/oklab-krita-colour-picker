#!/bin/sh
set -eu

PYTHON_BIN="${PYTHON:-python3}"
CHECK_SCRIPT="scripts/checks/dev_checks.py"

if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
  echo "ERROR: Python interpreter '$PYTHON_BIN' not found. Set PYTHON=/path/to/python or install python3." >&2
  exit 1
fi

if [ ! -x "$CHECK_SCRIPT" ]; then
  echo "ERROR: $CHECK_SCRIPT is missing or not executable. Run: $PYTHON_BIN $CHECK_SCRIPT --install-hooks" >&2
  exit 1
fi

"$PYTHON_BIN" "$CHECK_SCRIPT" --scope tracked --pytest
